# Environment Configuration Example
# Copy this file to .env.local and update with your values

# Environment
NODE_ENV=development

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# VPS Transcription Service (Whisper fallback)
VPS_API_URL=https://your-vps-domain.com
VPS_API_KEY=your-vps-api-key

# LLM Gateway
LLM_GATEWAY_URL=https://your-vps-domain.com/v1
LLM_GATEWAY_API_KEY=your-llm-gateway-api-key
LLM_MODEL=claude-sonnet-4-6

# Supabase Service Role Key (server-side only, used for cache writes and rate limiting)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Stripe (paywall — phase 2)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000